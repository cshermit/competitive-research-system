# ─────────────────────────────────────────────────────────────────────────────
# Competitive Research Agent — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Model to use (default: claude-sonnet-4-20250514)
LLM_MODEL=claude-sonnet-4-20250514

# ── Web Search ────────────────────────────────────────────────────────────────
# Get your free key at https://app.tavily.com
TAVILY_API_KEY=tvly-...

# ── Agent Tuning ──────────────────────────────────────────────────────────────
# Max subtasks the Planner will create per query (default: 4)
MAX_SUBTASKS=4

# Max retries per subtask before skipping (default: 2)
MAX_RETRIES_PER_SUBTASK=2

# Max search results returned per query (default: 5)
MAX_SEARCH_RESULTS=5

# Max URL characters to feed into LLM context (default: 4000)
MAX_URL_CONTENT_CHARS=4000

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO

# Directory for log files (default: ./logs)
LOG_DIR=./logs
